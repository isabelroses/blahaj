{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "baseUrl": "./",
        "paths": {
            "@root/*": [
                "./*"
            ],
            "@handlers/*": [
                "./src/handlers/*"
            ],
            "@helpers/*": [
                "./src/helpers/*"
            ],
            "@src/*": [
                "./src/*"
            ],
            "@structures/*": [
                "./src/structures/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}